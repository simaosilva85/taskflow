# Copiez ce fichier en .env et adaptez les valeurs.
# En production (Coolify), ces variables se définissent dans l'interface, PAS dans le dépôt.

# Port d'écoute de l'application
PORT=3000

# Identifiants PostgreSQL (doivent correspondre entre l'app et la base)
PGUSER=taskflow
PGPASSWORD=changez-moi
PGDATABASE=taskflow

# Alternative : une URL de connexion complète (prioritaire si définie)
# DATABASE_URL=postgres://taskflow:changez-moi@db:5432/taskflow
